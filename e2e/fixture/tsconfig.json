{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [],
    "noEmit": true,
    "rootDir": "../../.."
  },
  "include": ["**/*.ts", "**/*.tsx", "../panel.test.ts", "../../../src/i18n/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
